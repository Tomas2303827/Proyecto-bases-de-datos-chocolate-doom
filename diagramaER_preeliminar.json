  "sources": [
    {
      "id": "29c45327-431d-490c-9afc-bbeb3c709231",
      "name": "default",
      "kind": {
        "kind": "AmlEditor"
      },
      "content": [
        "type game_state (en_curso, completada, abandonada)",
        "type user_genre (masculino, femenino, no_binario)",
        "type user_level_of_exp (ninguno, principiante, intermedio, experto)",
        "type name_instrument (PENS, GUESS, BANGS)",
        "",
        "",
        "",
        "User",
        "  id uuid pk ",
        "  user_name varchar(128)",
        "  user_genre user_genre",
        "  user_level_of_exp user_level_of_exp",
        "  time_of_creation timestamp ",
        "",
        "Player",
        "  player_id uuid pk",
        "  player_name varchar(128)",
        "  user_id uuid -> User(id) ",
        "",
        "Map",
        "  id_map uuid pk",
        "  episode int ",
        "  map_code varchar(10) nullable",
        "  map_name varchar(128)",
        "  wide int",
        "  length int",
        "  end timestamp nullable",
        "",
        "Sector",
        "  sector_id uuid pk",
        "  map_id uuid -> Map(id_map)",
        "  sector_code varchar(10) nullable",
        "  descri text nullable",
        "",
        "Game",
        "  game_id uuid pk",
        "  mapa_id uuid -> Map(id_map)",
        "  state game_state",
        "  start timestampt",
        "",
        "Telemetry_event",
        "  tel_id uuid pk",
        "  participant_id uuid -> GameParticipant(participant_id)",
        "  tic int check (`tic >= 0`)",
        "  pos_x float",
        "  pox_y float",
        "  pos_z float",
        "  angulo float",
        "  momentum_x float",
        "  momentum_y float",
        "  momentum_z float",
        "  fov float nullable",
        "  salud int check (`salud >= 0 AND salud <= 200`)",
        "  armadura int check(`armadura >= 0`)",
        "  municion int check(`municion >= 0`)",
        "  registrado_en timestamp",
        "",
        "GameParticipant  ",
        "  participant_id uuid pk",
        "  game_id uuid -> Game(game_id)",
        "  player_id uuid -> Player(player_id)",
        "  join_time timestamp",
        "  leave_time timestamp nullable",
        "",
        "Instrument_UX",
        "  instrument_id uuid pk",
        "  name name_instrument",
        "  version varchar(10)",
        "  description text nullable",
        "  min int",
        "  max int",
        "",
        "Item_UX",
        "  item_id uuid pk",
        "  instrument_id uuid -> Instrument_UX(instrument_id)",
        "  ",
        "",
        ""
      ],
